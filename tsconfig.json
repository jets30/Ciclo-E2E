{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node16",
    "resolveJsonModule": true,
    "isolatedModules": false,
    "skipLibCheck": true,
    "types": ["node", "@playwright/test", "@cucumber/cucumber"],
    "outDir": "./dist"
  },
  "include": ["tests/**/*.ts", "playwright.config.ts", "features/**/*.ts"],
  "exclude": ["node_modules"]
}
